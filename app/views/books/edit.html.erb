<h1>Editing Book</h1>

<%= form_with model: @book do |f| %>

  <h4>Title</h4>
  <%= f.text_field :title %>

  <h4>Body</h4>
  <%= f.text_area :body %>

  <%= f.submit 'Update Book' %>

  <%# 編集ページへのリンク %>
  <%= link_to 'Show', book_path(@book) %>

  <%# 一覧ページへ戻るリンク %>
  <%= link_to 'Back', books_path %>

<% end %>